{
  "name": "@dzipagent/connectors",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage",
    "test:esm-smoke": "node ./scripts/esm-smoke.mjs",
    "build:verified": "yarn build && yarn test:esm-smoke"
  },
  "dependencies": {
    "@dzipagent/core": "0.1.0",
    "pg": "^8.13.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.32",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
