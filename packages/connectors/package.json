{
  "name": "@dzupagent/connectors",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage",
    "test:esm-smoke": "node ./scripts/esm-smoke.mjs",
    "build:verified": "yarn build && yarn test:esm-smoke"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/flow-ast": "0.2.0",
    "@google-cloud/bigquery": "^8.1.1",
    "better-sqlite3": "^12.8.0",
    "duckdb": "^1.4.4",
    "mssql": "^12.2.1",
    "mysql2": "^3.19.1",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.13.0",
    "snowflake-sdk": "^2.3.6"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "@types/pg": "^8.11.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
