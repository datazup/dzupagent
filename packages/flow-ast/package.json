{
  "name": "@dzupagent/flow-ast",
  "version": "0.2.0",
  "type": "module",
  "description": "Flow AST type definitions for DzupAgent flow-compiler — pure, runtime-free types shared across compiler stages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
