{
  "name": "@dzupagent/agent-types",
  "version": "0.2.0",
  "type": "module",
  "description": "Shared type primitives consumed by @dzupagent/agent and @dzupagent/agent-adapters (Layer 0: no runtime deps)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}
