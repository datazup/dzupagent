{
  "name": "@dzupagent/agent-types",
  "version": "0.2.0",
  "type": "module",
  "description": "Shared type primitives consumed by @dzupagent/agent and @dzupagent/agent-adapters (Layer 0: no runtime deps)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fleet": {
      "types": "./dist/fleet.d.ts",
      "import": "./dist/fleet.js"
    },
    "./implementation": {
      "types": "./dist/implementation.d.ts",
      "import": "./dist/implementation.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/agent-types"
  }
}
