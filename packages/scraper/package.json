{
  "name": "@dzupagent/scraper",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@dzupagent/core": "0.2.0"
  },
  "peerDependencies": {
    "puppeteer": ">=21.0.0",
    "puppeteer-extra": ">=3.3.0",
    "puppeteer-extra-plugin-stealth": ">=2.11.0"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    },
    "puppeteer-extra": {
      "optional": true
    },
    "puppeteer-extra-plugin-stealth": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/scraper"
  }
}
