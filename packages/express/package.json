{
  "name": "@dzupagent/express",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@dzupagent/agent": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@langchain/core": "^1.1.39",
    "express-rate-limit": "^8.5.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "express": ">=4.22.1 <5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.0.0",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/express"
  }
}
