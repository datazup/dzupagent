{
  "name": "@dzupagent/test-utils",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/core": "0.2.0",
    "@dzupagent/testing": "0.2.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "express": ">=4.22.1 <5",
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "@types/express": "^5.0.6",
    "express": "^4.22.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/test-utils"
  }
}
