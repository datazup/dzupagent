{
  "name": "@dzupagent/code-edit-kit",
  "version": "0.2.0",
  "type": "module",
  "description": "Structured code-edit tooling (apply_patch, validation hooks, edit policies) for DzupAgent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@dzupagent/codegen": "0.2.0",
    "@langchain/core": ">=1.0.0",
    "ts-morph": ">=21",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ts-morph": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dzupagent/codegen": "0.2.0",
    "@langchain/core": "^1.1.39",
    "@types/node": "^20.0.0",
    "ts-morph": "^23.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "license": "MIT"
}
