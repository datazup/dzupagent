{
  "name": "@dzupagent/code-edit-kit",
  "version": "0.2.0",
  "type": "module",
  "description": "Structured code-edit tooling (apply_patch, validation hooks, edit policies) for DzupAgent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
