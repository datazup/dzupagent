{
  "name": "@dzupagent/playground",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/ --ext .vue,.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "pinia": "^3.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.5",
    "@vue/tsconfig": "^0.5.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^5.2.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.6"
  },
  "license": "MIT"
}
