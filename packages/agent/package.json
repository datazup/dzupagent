      "types": "./dist/self-correction.d.ts",
      "import": "./dist/self-correction.js"
    },
    "./replay": {
      "types": "./dist/replay.d.ts",
      "import": "./dist/replay.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline.d.ts",
      "import": "./dist/pipeline.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./compat": {
      "types": "./dist/compat.d.ts",
      "import": "./dist/compat.js"
    },
    "./mailbox": {
      "types": "./dist/mailbox.d.ts",
      "import": "./dist/mailbox.js"
    },
    "./cluster": {
      "types": "./dist/cluster.d.ts",
      "import": "./dist/cluster.js"
    },
    "./reflection": {
      "types": "./dist/reflection.d.ts",
      "import": "./dist/reflection.js"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js"
    },
    "./streaming": {
      "types": "./dist/streaming.d.ts",
      "import": "./dist/streaming.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/adapter-types": "0.2.0",
    "@dzupagent/agent-types": "0.2.0",
    "@dzupagent/context": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/memory": "0.2.0",
    "@dzupagent/memory-ipc": "0.2.0",
    "@dzupagent/runtime-contracts": "0.2.0",
    "@dzupagent/security": "0.2.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.5",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
