{
  "name": "@dzupagent/app-tools",
  "version": "0.2.0",
  "type": "module",
  "description": "Domain tool registry for DzupAgent — defines DomainToolDefinition, permissions, and in-memory registry",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@dzupagent/code-edit-kit": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/hitl-kit": "0.2.0"
  },
  "peerDependenciesMeta": {
    "@dzupagent/code-edit-kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dzupagent/code-edit-kit": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/hitl-kit": "0.2.0",
    "@types/node": "^22.13.0",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/app-tools"
  }
}
