    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dzupagent/flow-ast": "0.2.0"
  },
  "devDependencies": {
    "@dzupagent/flow-ast": "0.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "license": "MIT"
}
