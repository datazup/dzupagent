{
  "name": "@dzupagent/flow-dsl",
  "version": "0.2.0",
  "type": "module",
  "description": "Textual dzupflow/v1 DSL parser, formatter, validator, and graph projection for DzupAgent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dzupagent/flow-ast": "0.2.0"
  },
  "devDependencies": {
    "@dzupagent/flow-ast": "0.2.0",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/flow-dsl"
  }
}
