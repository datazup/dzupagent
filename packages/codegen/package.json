{
  "name": "@dzupagent/codegen",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vfs": {
      "import": "./dist/vfs.js",
      "types": "./dist/vfs.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    },
    "./compat": {
      "import": "./dist/compat.js",
      "types": "./dist/compat.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationMap false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/adapter-types": "0.2.0",
    "@dzupagent/core": "0.2.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "tree-sitter-wasms": ">=0.1.0",
    "web-tree-sitter": ">=0.22.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter-wasms": {
      "optional": true
    },
    "web-tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dzupagent/agent": "0.2.0",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.5",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/codegen"
  }
}
