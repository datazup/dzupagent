{
  "name": "@dzupagent/agent-adapters",
  "version": "0.2.0",
  "type": "module",
  "description": "AI agent CLI/SDK adapters for DzupAgent — orchestrate Claude, Codex, Gemini, Qwen, and Crush agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration.d.ts",
      "import": "./dist/orchestration.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "import": "./dist/persistence.js"
    },
    "./runs": {
      "types": "./dist/runs/index.d.ts",
      "import": "./dist/runs/index.js"
    },
    "./integration": {
      "types": "./dist/integration/index.d.ts",
      "import": "./dist/integration/index.js"
    },
    "./dzupagent": {
      "types": "./dist/dzupagent/index.d.ts",
      "import": "./dist/dzupagent/index.js"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "import": "./dist/rules.js"
    },
    "./learning": {
      "types": "./dist/learning.d.ts",
      "import": "./dist/learning.js"
    },
    "./recovery": {
      "types": "./dist/recovery.d.ts",
      "import": "./dist/recovery.js"
    },
    "./skills": {
      "types": "./dist/skills.d.ts",
      "import": "./dist/skills.js"
    },
    "./enrichment": {
      "types": "./dist/enrichment.d.ts",
      "import": "./dist/enrichment.js"
    },
    "./fleet-executors": {
      "types": "./dist/fleet-executors/index.d.ts",
      "import": "./dist/fleet-executors/index.js"
    },
    "./subagents": {
      "types": "./dist/subagents/index.d.ts",
      "import": "./dist/subagents/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationMap false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:orchestration:race": "vitest run src/__tests__/parallel-executor.test.ts src/__tests__/orchestrator-facade.test.ts src/__tests__/parallel-executor.contract.test.ts src/__tests__/parallel-executor-unhandled-rejection.test.ts",
    "test:orchestration:cancel": "vitest run src/__tests__/parallel-executor.test.ts src/__tests__/orchestrator-facade.test.ts src/__tests__/contract-net.test.ts src/__tests__/map-reduce.test.ts",
    "test:orchestration:contracts": "vitest run src/__tests__/parallel-executor.contract.test.ts src/__tests__/parallel-executor-unhandled-rejection.test.ts src/__tests__/adapter-registry.test.ts src/__tests__/event-bus-bridge.test.ts",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/adapter-rules": "0.1.0",
    "@dzupagent/adapter-types": "0.2.0",
    "@dzupagent/agent": "0.2.0",
    "@dzupagent/agent-types": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/runtime-contracts": "0.2.0",
    "@dzupagent/security": "0.2.0",
    "@dzupagent/subagents": "0.1.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.162",
    "@google/generative-ai": "^0.24.1",
    "@openai/codex-sdk": "^0.136.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/agent-adapters"
  }
}
