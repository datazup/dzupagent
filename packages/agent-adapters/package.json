{
  "name": "@dzipagent/agent-adapters",
  "version": "0.1.0",
  "type": "module",
  "description": "AI agent CLI/SDK adapters for DzipAgent — orchestrate Claude, Codex, Gemini, Qwen, and Crush agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzipagent/core": "0.1.0",
    "@dzipagent/agent": "0.1.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@openai/codex-sdk": "^0.117.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.32",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
