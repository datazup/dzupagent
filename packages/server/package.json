{
  "name": "@dzupagent/server",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "dzup": "dist/cli/dzup.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ops": {
      "import": "./dist/ops.js",
      "types": "./dist/ops.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    },
    "./compat": {
      "import": "./dist/compat.js",
      "types": "./dist/compat.d.ts"
    },
    "./features": {
      "import": "./dist/features.js",
      "types": "./dist/features.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationMap false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/agent": "0.2.0",
    "@dzupagent/agent-adapters": "0.2.0",
    "@dzupagent/app-tools": "0.2.0",
    "@dzupagent/context": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/eval-contracts": "0.2.0",
    "@dzupagent/flow-ast": "0.2.0",
    "@dzupagent/flow-compiler": "0.2.0",
    "@dzupagent/hitl-kit": "0.2.0",
    "@dzupagent/memory-ipc": "0.2.0",
    "@dzupagent/otel": "0.2.0",
    "@dzupagent/security": "0.2.0",
    "@langchain/core": "^1.1.39",
    "commander": "^12.1.0",
    "cron-parser": "^4.9.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16"
  },
  "peerDependencies": {
    "bullmq": "^5.0.0",
    "postgres": "^3.4.0"
  },
  "optionalDependencies": {
    "@dzupagent/codegen": "0.2.0",
    "@dzupagent/connectors": "0.2.0",
    "@dzupagent/memory": "0.2.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dzupagent/evals": "0.2.0",
    "@dzupagent/test-utils": "0.2.0",
    "bullmq": "^5.71.1",
    "drizzle-kit": "^0.31.9",
    "testcontainers": "^10.0.0",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/server"
  }
}
