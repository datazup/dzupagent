{
  "name": "@dzipagent/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzipagent/agent": "0.1.0",
    "@dzipagent/core": "0.1.0",
    "@dzipagent/memory-ipc": "0.1.0",
    "@langchain/core": "^1.1.32",
    "drizzle-orm": "^0.40.1",
    "hono": "^4.12.9"
  },
  "peerDependencies": {
    "postgres": "^3.4.0",
    "bullmq": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    }
  },
  "devDependencies": {
    "bullmq": "^5.0.0",
    "drizzle-kit": "^0.30.0",
    "testcontainers": "^10.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
