{
  "name": "@dzupagent/execution-contracts",
  "version": "0.1.0",
  "type": "module",
  "description": "Neutral execution isolation policies, validation, and qualification receipts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/execution-contracts"
  }
}
