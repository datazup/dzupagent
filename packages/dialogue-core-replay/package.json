{
  "name": "@dzupagent/dialogue-core-replay",
  "version": "0.2.0",
  "type": "module",
  "description": "Deterministic replay harness ports for DzupAgent dialogue-core",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
