{
  "name": "@dzupagent/flow-compiler",
  "version": "0.2.0",
  "type": "module",
  "description": "Flow compiler for DzupAgent — compiles flow-ast into skill-chain, workflow-builder, or pipeline artifacts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "dzupagent-compile": "./dist/bin/compile.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@dzupagent/core": "0.2.0",
    "@dzupagent/flow-ast": "0.2.0"
  },
  "dependencies": {
    "@dzupagent/flow-dsl": "0.2.0"
  },
  "devDependencies": {
    "@dzupagent/app-tools": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/flow-ast": "0.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
