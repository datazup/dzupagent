{
  "name": "@dzupagent/flow-compiler",
  "version": "0.2.0",
  "type": "module",
  "description": "Flow compiler for DzupAgent — compiles flow-ast into skill-chain, workflow-builder, or pipeline artifacts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "dzupagent-compile": "dist/bin/compile.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@dzupagent/core": "0.2.0",
    "@dzupagent/flow-ast": "0.2.0"
  },
  "dependencies": {
    "@dzupagent/flow-dsl": "0.2.0"
  },
  "devDependencies": {
    "@dzupagent/app-tools": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/flow-ast": "0.2.0",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/flow-compiler"
  }
}
