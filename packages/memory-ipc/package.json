{
  "name": "@forgeagent/memory-ipc",
  "version": "0.1.0",
  "description": "Arrow-based IPC for inter-agent memory sharing in ForgeAgent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "apache-arrow": "^19.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@forgeagent/memory": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@forgeagent/memory": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
