{
  "name": "@dzipagent/core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./quick-start": {
      "import": "./dist/facades/quick-start.js",
      "types": "./dist/facades/quick-start.d.ts"
    },
    "./memory": {
      "import": "./dist/facades/memory.js",
      "types": "./dist/facades/memory.d.ts"
    },
    "./orchestration": {
      "import": "./dist/facades/orchestration.js",
      "types": "./dist/facades/orchestration.d.ts"
    },
    "./security": {
      "import": "./dist/facades/security.js",
      "types": "./dist/facades/security.d.ts"
    },
    "./facades": {
      "import": "./dist/facades/index.js",
      "types": "./dist/facades/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzipagent/memory": "0.1.0",
    "@dzipagent/context": "0.1.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "@dzipagent/memory-ipc": "*",
    "zod": ">=4.0.0",
    "@lancedb/lancedb": ">=0.10.0",
    "apache-arrow": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "@dzipagent/memory-ipc": {
      "optional": true
    },
    "@lancedb/lancedb": {
      "optional": true
    },
    "apache-arrow": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/anthropic": "^1.3.0",
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@langchain/openai": "^1.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
