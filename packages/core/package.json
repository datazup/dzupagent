{
  "name": "@dzupagent/core",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./stable": {
      "import": "./dist/stable.js",
      "types": "./dist/stable.d.ts"
    },
    "./advanced": {
      "import": "./dist/advanced.js",
      "types": "./dist/advanced.d.ts"
    },
    "./quick-start": {
      "import": "./dist/facades/quick-start.js",
      "types": "./dist/facades/quick-start.d.ts"
    },
    "./orchestration": {
      "import": "./dist/facades/orchestration.js",
      "types": "./dist/facades/orchestration.d.ts"
    },
    "./security": {
      "import": "./dist/facades/security.js",
      "types": "./dist/facades/security.d.ts"
    },
    "./facades": {
      "import": "./dist/facades/index.js",
      "types": "./dist/facades/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/agent-types": "0.2.0",
    "@dzupagent/runtime-contracts": "0.2.0"
  },
  "peerDependencies": {
    "@lancedb/lancedb": ">=0.10.0",
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "apache-arrow": ">=15.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@lancedb/lancedb": {
      "optional": true
    },
    "apache-arrow": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.4.3",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
