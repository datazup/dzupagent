{
  "name": "@dzupagent/context",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/memory-ipc": "0.2.0"
  },
  "peerDependencies": {
    "@anthropic-ai/tokenizer": ">=0.0.4",
    "@langchain/core": ">=1.0.0",
    "js-tiktoken": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/tokenizer": {
      "optional": true
    },
    "js-tiktoken": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "apache-arrow": "19",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/context"
  }
}
