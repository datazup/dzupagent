{
  "name": "@dzupagent/memory",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./knowledge": {
      "import": "./dist/knowledge/index.js",
      "types": "./dist/knowledge/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --pretty false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/agent-types": "0.2.0",
    "@dzupagent/cache": "0.2.0",
    "@dzupagent/memory-ipc": "0.2.0",
    "proper-lockfile": "^4.1.2",
    "ulidx": "^2.4.1"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "ioredis": ">=5.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@types/proper-lockfile": "^4.1.4",
    "ioredis": "^5.8.2",
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/memory"
  }
}
