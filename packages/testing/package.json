{
  "name": "@dzupagent/testing",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vitest-llm-setup": {
      "import": "./dist/vitest-llm-setup.js",
      "types": "./dist/vitest-llm-setup.d.ts"
    }
  },
  "bin": {
    "dzupagent-sdlc-mvp-evidence": "./dist/bin/sdlc-mvp-evidence.js"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dzupagent/agent": "0.2.0",
    "@dzupagent/core": "0.2.0",
    "@dzupagent/flow-compiler": "0.2.0"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datazup/dzupagent.git",
    "directory": "packages/testing"
  }
}
