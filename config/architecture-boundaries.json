  "layerGraph": {
    "description": "Directed acyclic layer graph for @dzupagent packages. Each package is assigned exactly one layer. A package may only depend on packages in lower-numbered layers. Layer 0 is a leaf primitive layer: it may contain dependency-light runtime primitives when they do not depend on other @dzupagent packages. Tier metadata for each package lives in config/package-tiers.json — do not duplicate it here.",
    "layers": [
      {
        "id": 0,
        "name": "leaf-primitives",
        "runtimeProfile": "leaf-runtime-primitives",
        "description": "Shared contracts and dependency-light leaf runtime primitives. May not depend on any other @dzupagent package; external runtime dependencies are allowed when the package docs and description identify the runtime role.",
        "packages": [
          "adapter-types",
          "agent-types",
          "runtime-contracts",
          "eval-contracts",
          "cache",
          "memory-ipc",
          "hitl-kit",
          "flow-ast",
          "security"
        ]
      },
      {
        "id": 1,
        "name": "foundation",
        "description": "Core foundation built on contracts. May depend only on layer 0.",
        "packages": [
          "core",
          "adapter-rules",
          "flow-dsl",
          "memory",
          "context"
        ]
      },
      {
        "id": 2,
        "name": "domain",
        "description": "Single-purpose domain capabilities. May depend on layers 0–1.",
        "packages": [
          "codegen",
          "connectors",
          "connectors-browser",
          "connectors-documents",
          "evals",
          "otel",
          "scraper",
          "rag",
          "flow-compiler"
        ]
      },
      {
        "id": 3,
        "name": "orchestration",
        "description": "Agent runtime and orchestration. May depend on layers 0–2.",
        "packages": [
          "agent",
          "code-edit-kit"
        ]
      },
      {
        "id": 4,
        "name": "composition",
        "description": "Composition and adapter packages that bind multiple orchestration units. May depend on layers 0–3.",
        "packages": [
          "agent-adapters",
          "app-tools",
          "express"
        ]
      },
      {
        "id": 5,
        "name": "host",
        "description": "Host runtimes. Top of the dependency graph; nothing may depend on this layer.",
        "packages": [
          "server"
        ]
      },
      {
        "id": 98,
        "name": "tooling-base",
        "description": "Base tooling packages. These are the canonical home for test infrastructure (eval, security suites, LLM recorder) and CLI scaffolders. May depend on lower numbered layers but must never appear upstream of supported product packages. test-utils (layer 99) may depend on packages in this layer.",
        "packages": [
          "testing",
          "create-dzupagent"
        ]
      },
      {
        "id": 99,
        "name": "tooling",
        "description": "Top-level tooling shim packages. May depend on tooling-base (layer 98) and lower layers. Tier-1 and tier-2 packages MUST NOT take a runtime dependency on any tooling package. Tooling packages must never appear upstream of supported product packages.",
        "packages": [
          "test-utils"
        ]
      }
    ],
    "rules": {
      "allowSameLayerEdges": false,
      "layerZeroRuntimeProfile": "leaf-runtime-primitives",
      "layerZeroMayHaveExternalRuntimeDeps": true,
      "toolingMayBeUpstreamOfSupported": false,
      "toolingLayerId": 99,
      "supportedTiers": [
        1,
        2
      ]
    }
  }
}
