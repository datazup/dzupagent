{
  "packageBoundaryRules": [
    {
      "importer": "core",
      "forbidden": ["agent", "codegen", "connectors", "server", "agent-adapters"]
    },
    {
      "importer": "agent",
      "forbidden": ["server"]
    },
    {
      "importer": "codegen",
      "forbidden": ["agent", "server", "connectors"]
    },
    {
      "importer": "connectors",
      "forbidden": ["agent", "codegen", "server"]
    },
    {
      "importer": "agent-adapters",
      "forbidden": ["server"]
    },
    {
      "importer": "server",
      "forbidden": ["create-dzupagent", "testing", "test-utils"]
    }
  ],
  "appWorkspaces": [
    {
      "dirName": "ai-saas-starter-kit",
      "packageName": "ai-saas-starter-kit"
    },
    {
      "dirName": "blood-pressure",
      "packageName": "blood-pressure"
    },
    {
      "dirName": "codeindex-app",
      "packageName": "codeindex-app"
    },
    {
      "dirName": "codev-app",
      "packageName": "codev-app"
    },
    {
      "dirName": "nl2sql",
      "packageName": "nl2sql-engine"
    },
    {
      "dirName": "research-app",
      "packageName": "research-app"
    },
    {
      "dirName": "seo-batch",
      "packageName": "seo-batch"
    },
    {
      "dirName": "template-app",
      "packageName": "template-app"
    },
    {
      "dirName": "testman-app",
      "packageName": "testman-app"
    },
    {
      "dirName": "textflow-rag",
      "packageName": "textflow-rag"
    }
  ],
  "serverRouteBoundaries": {
    "description": "packages/server route files are frozen as framework/runtime compatibility infrastructure. New product-control-plane routes belong in consuming apps and should integrate through ServerRoutePlugin or app-owned Hono composition instead of expanding packages/server.",
    "routeFileClassifications": {
      "framework-primitive": {
        "rationale": "Generic DzupAgent runtime primitives that framework hosts can reuse across products.",
        "files": [
          "packages/server/src/routes/agents.ts",
          "packages/server/src/routes/analytics-handler.ts",
          "packages/server/src/routes/api-keys.ts",
          "packages/server/src/routes/approval.ts",
          "packages/server/src/routes/approvals.ts",
          "packages/server/src/routes/capabilities.ts",
          "packages/server/src/routes/enrichment-metrics.ts",
          "packages/server/src/routes/events.ts",
          "packages/server/src/routes/health.ts",
          "packages/server/src/routes/human-contact.ts",
          "packages/server/src/routes/memory-browse.ts",
          "packages/server/src/routes/memory-health.ts",
          "packages/server/src/routes/memory-sync.ts",
          "packages/server/src/routes/memory-tenant-scope.ts",
          "packages/server/src/routes/memory.ts",
          "packages/server/src/routes/metrics.ts",
          "packages/server/src/routes/registry.ts",
          "packages/server/src/routes/routing-stats.ts",
          "packages/server/src/routes/run-context.ts",
          "packages/server/src/routes/run-guard.ts",
          "packages/server/src/routes/run-trace.ts",
          "packages/server/src/routes/runs.ts",
          "packages/server/src/routes/schemas.ts"
        ]
      },
      "compatibility-maintenance": {
        "rationale": "Existing optional or compatibility route surfaces kept source-compatible for framework hosts; not the forward path for new product features.",
        "files": [
          "packages/server/src/routes/a2a.ts",
          "packages/server/src/routes/a2a/helpers.ts",
          "packages/server/src/routes/a2a/index.ts",
          "packages/server/src/routes/a2a/jsonrpc-handlers.ts",
          "packages/server/src/routes/a2a/jsonrpc-route.ts",
          "packages/server/src/routes/a2a/message-routes.ts",
          "packages/server/src/routes/a2a/task-routes.ts",
          "packages/server/src/routes/a2a/well-known.ts",
          "packages/server/src/routes/benchmarks.ts",
          "packages/server/src/routes/clusters.ts",
          "packages/server/src/routes/deploy.ts",
          "packages/server/src/routes/evals.ts",
          "packages/server/src/routes/learning.ts",
          "packages/server/src/routes/mailbox.ts",
          "packages/server/src/routes/marketplace.ts",
          "packages/server/src/routes/openai-compat/auth-middleware.ts",
          "packages/server/src/routes/openai-compat/completion-mapper.ts",
          "packages/server/src/routes/openai-compat/completions.ts",
          "packages/server/src/routes/openai-compat/index.ts",
          "packages/server/src/routes/openai-compat/models-route.ts",
          "packages/server/src/routes/openai-compat/request-mapper.ts",
          "packages/server/src/routes/openai-compat/types.ts",
          "packages/server/src/routes/personas.ts",
          "packages/server/src/routes/playground.ts",
          "packages/server/src/routes/presets.ts",
          "packages/server/src/routes/prompts.ts",
          "packages/server/src/routes/reflections.ts",
          "packages/server/src/routes/schedules.ts",
          "packages/server/src/routes/triggers.ts"
        ]
      },
      "route-plugin-host-seam": {
        "rationale": "Route families mounted through server plugin seams or app-selected framework capabilities; consuming apps own product-specific route composition.",
        "files": [
          "packages/server/src/routes/compile-input.ts",
          "packages/server/src/routes/compile-result-event.ts",
          "packages/server/src/routes/compile.ts",
          "packages/server/src/routes/mcp.ts",
          "packages/server/src/routes/skills.ts",
          "packages/server/src/routes/spawn-compiler-bridge.ts",
          "packages/server/src/routes/workflows.ts"
        ]
      },
      "internal-support": {
        "rationale": "Shared route support modules that do not create product-control-plane endpoints by themselves.",
        "files": [
          "packages/server/src/routes/route-error.ts"
        ]
      }
    }
  },
  "layerGraph": {
    "description": "Directed acyclic layer graph for @dzupagent packages. Each package is assigned exactly one layer. A package may only depend on packages in lower-numbered layers (or share a layer for sibling type-only contracts). Tier metadata for each package lives in config/package-tiers.json — do not duplicate it here.",
    "layers": [
      {
        "id": 0,
        "name": "contracts",
        "description": "Type-only / zero-runtime-dep foundations. May not depend on any other @dzupagent package.",
        "packages": [
          "adapter-types",
          "agent-types",
          "runtime-contracts",
          "eval-contracts",
          "cache",
          "memory-ipc",
          "hitl-kit",
          "flow-ast"
        ]
      },
      {
        "id": 1,
        "name": "foundation",
        "description": "Core foundation built on contracts. May depend only on layer 0.",
        "packages": [
          "core",
          "adapter-rules",
          "flow-dsl",
          "memory",
          "context"
        ]
      },
      {
        "id": 2,
        "name": "domain",
        "description": "Single-purpose domain capabilities. May depend on layers 0–1.",
        "packages": [
          "codegen",
          "connectors",
          "connectors-browser",
          "connectors-documents",
          "evals",
          "otel",
          "scraper",
          "rag",
          "flow-compiler"
        ]
      },
      {
        "id": 3,
        "name": "orchestration",
        "description": "Agent runtime and orchestration. May depend on layers 0–2.",
        "packages": [
          "agent",
          "code-edit-kit"
        ]
      },
      {
        "id": 4,
        "name": "composition",
        "description": "Composition and adapter packages that bind multiple orchestration units. May depend on layers 0–3.",
        "packages": [
          "agent-adapters",
          "app-tools",
          "express"
        ]
      },
      {
        "id": 5,
        "name": "host",
        "description": "Host runtimes. Top of the dependency graph; nothing may depend on this layer.",
        "packages": [
          "server"
        ]
      },
      {
        "id": 99,
        "name": "tooling",
        "description": "Parked / tooling packages. Tier-1 and tier-2 packages MUST NOT take a runtime dependency on any tooling package. Tooling packages may depend on lower numbered layers but must never appear upstream of supported product packages.",
        "packages": [
          "testing",
          "test-utils",
          "create-dzupagent"
        ]
      }
    ],
    "rules": {
      "allowSameLayerEdges": false,
      "toolingMayBeUpstreamOfSupported": false,
      "toolingLayerId": 99,
      "supportedTiers": [1, 2]
    }
  }
}
