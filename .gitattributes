* text=auto eol=lf

# Binaries — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Scripts — must keep LF even on Windows
*.sh text eol=lf
*.bash text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Lockfiles — leave alone
yarn.lock -text
package-lock.json -text
