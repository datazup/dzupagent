{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/agent" },
    { "path": "packages/codegen" },
    { "path": "packages/memory" },
    { "path": "packages/memory-ipc" },
    { "path": "packages/context" },
    { "path": "packages/server" },
    { "path": "packages/otel" },
    { "path": "packages/evals" },
    { "path": "packages/testing" },
    { "path": "packages/test-utils" },
    { "path": "packages/connectors" },
    { "path": "packages/domain-nl2sql" },
    { "path": "packages/playground" },
    { "path": "packages/create-dzipagent" }
  ]
}
